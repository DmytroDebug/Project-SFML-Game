{
    "configurations": [
        {
            "name": "Run Game",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\game.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "D:\\libs\\SFML-3.1.0\\bin;D:\\MSYS2\\ucrt64\\bin;${env:PATH}"
                }
